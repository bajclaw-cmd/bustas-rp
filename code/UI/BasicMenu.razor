@using System
@using Sandbox;
@using Sandbox.UI;
@using System.Threading.Tasks;
@using System.Text.RegularExpressions;
@using System;
@using global::Entity.Interactable.Printer
@using global::Entity.Interactable.Props
@using global::Entity.Vehicle
@using global::GameSystems
@using global::GameSystems.Jobs
@using Sandbox.Entities.Interactable.Props
@using Sandbox.GameSystems
@using Sandbox.GameSystems.Player

@inherits PanelComponent;

<root>
    <div class="title">@BustasConfig.ServerName</div>

    <div class="main">
        <div class="side-bar">
            <div class="player-container">
                <div class="name">@(Network.Owner.DisplayName.Truncate(13))</div>
                <div class="wallet">$@(Player.Balance.ToString("N0"))</div>
                <div class="sub">Salary:<span>$@(GameController.Instance.GetMe().Job.Salary.ToString("N0"))</span></div>
                <div class="sub">Job:<span>@(GameController.Instance.GetMe().Job.Name)</span></div>
            </div>
            <div class="navigation">
                <div class="buttoncontainer">
                    <button class="button @(IsJobsVisible ? "active" : "")" onclick="@DisplayJobs">
                        <i class="icon">work</i> Jobs
                    </button>
                    <button class="button @(IsDarkWebVisible ? "active" : "")" onclick="@DisplayDarkWeb">
                        <i class="icon">store</i> Dark Web
                    </button>
                    <button class="button @(IsVehiclesVisible ? "active" : "")" onclick="@DisplayVehicles">
                        <i class="icon">directions_car</i> Vehicles
                    </button>
                    <button class="button @(IsPropsVisible ? "active" : "")" onclick="@DisplayProps">
                        <i class="icon">folder</i> Props
                    </button>
                </div>
                <div class="buttoncontainer">
                    <button class="button @(IsAdminVisible ? "active" : "")" onclick="@DisplayAdmin">
                        <i class="icon">local_police</i> Admin Tools
                    </button>
                    <button class="button @(IsInfoVisible ? "active" : "")" onclick="@DisplayInfo">
                        <i class="icon">info</i> Information
                    </button>
                    <button class="button" onclick=@GitHubLink style="color:#4078c0;">
                        <i class="icon">web</i> @GitHub
                    </button>
                    <button class="button" onclick=@DiscordLink style="color:#7289da;">
                        <i class="icon">discord</i> @Discord
                    </button>
                </div>
            </div>
        </div>
        <div class="main-container">
            <!-- Dark Web Section -->
            <div class="section" style="display: @(IsDarkWebVisible ? "flex" : "none");">
                <div class="section-title">Dark Web - Money Printers (@CurrentPrinter / @BustasConfig.MaxPrintersPerPlayer)</div>
                <div class="section-contents">

                    <div class="button" onclick=@(() => BuyPrinter(PrinterLogic.PrinterType.Bronze))>
                        <div class="icon" style="background-color: #CD7F32"></div>
                        <div class="label-container">
                            <div class="label">Bronze Printer</div>
                            <span class="description">$@(BustasConfig.PrinterBronzeRate.ToString("N0")) / cycle | @((BustasConfig.OverheatBronze * 100).ToString("N0"))% overheat</span>
                            <div class="price">$@(BustasConfig.PrinterBronzeCost.ToString("N0"))</div>
                        </div>
                    </div>

                    <div class="button" onclick=@(() => BuyPrinter(PrinterLogic.PrinterType.Silver))>
                        <div class="icon" style="background-color: #C0C0C0"></div>
                        <div class="label-container">
                            <div class="label">Silver Printer</div>
                            <span class="description">$@(BustasConfig.PrinterSilverRate.ToString("N0")) / cycle | @((BustasConfig.OverheatSilver * 100).ToString("N0"))% overheat</span>
                            <div class="price">$@(BustasConfig.PrinterSilverCost.ToString("N0"))</div>
                        </div>
                    </div>

                    <div class="button" onclick=@(() => BuyPrinter(PrinterLogic.PrinterType.Gold))>
                        <div class="icon" style="background-color: #FFD700"></div>
                        <div class="label-container">
                            <div class="label">Gold Printer</div>
                            <span class="description">$@(BustasConfig.PrinterGoldRate.ToString("N0")) / cycle | @((BustasConfig.OverheatGold * 100).ToString("N0"))% overheat</span>
                            <div class="price">$@(BustasConfig.PrinterGoldCost.ToString("N0"))</div>
                        </div>
                    </div>

                    <div class="button" onclick=@(() => BuyPrinter(PrinterLogic.PrinterType.Diamond))>
                        <div class="icon" style="background-color: #40E0D0"></div>
                        <div class="label-container">
                            <div class="label">Diamond Printer</div>
                            <span class="description">$@(BustasConfig.PrinterDiamondRate.ToString("N0")) / cycle | @((BustasConfig.OverheatDiamond * 100).ToString("N0"))% overheat</span>
                            <div class="price">$@(BustasConfig.PrinterDiamondCost.ToString("N0"))</div>
                        </div>
                    </div>

                    <div class="button" onclick=@(() => BuyPrinter(PrinterLogic.PrinterType.Emerald)) style="border-color: #50C878;">
                        <div class="icon" style="background-color: #50C878"></div>
                        <div class="label-container">
                            <div class="label">Emerald Printer <span style="color: #50C878; font-size: 14px;">(VIP)</span></div>
                            <span class="description">$@(BustasConfig.PrinterEmeraldRate.ToString("N0")) / cycle | @((BustasConfig.OverheatEmerald * 100).ToString("N0"))% overheat</span>
                            <div class="price">$@(BustasConfig.PrinterEmeraldCost.ToString("N0"))</div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Vehicles Section -->
            <div class="section" style="display: @(IsVehiclesVisible ? "flex" : "none");">
                <div class="section-title">Vehicles (@CurrentVehicleCount / @BustasConfig.MaxVehiclesPerPlayer)</div>
                <div class="section-contents">

                    @foreach (var kvp in VehicleConfigs.All)
                    {
                        var config = kvp.Value;
                        var canUse = CanUseVehicle(config);
                        var restrictionLabel = GetVehicleRestriction(config);

                        <div class="button @(!canUse ? "disabled" : "")" onclick=@(() => SpawnVehicle(kvp.Key)) style="opacity: @(!canUse ? "0.5" : "1")">
                            <div class="icon" style="background-color: rgba(@(config.DisplayColor.r * 255), @(config.DisplayColor.g * 255), @(config.DisplayColor.b * 255), 1)"></div>
                            <div class="label-container">
                                <div class="label">@config.DisplayName @(restrictionLabel)</div>
                                <span class="description">Speed: @config.SpeedLabel | Health: @config.HealthLabel</span>
                                <div class="price">@(config.IsFree ? "FREE" : $"${config.Cost:N0}")</div>
                            </div>
                        </div>
                    }

                </div>
            </div>

            <!-- Jobs Section -->
            <div class="section" style="display: @(IsJobsVisible ? "flex" : "none");">
                <div class="section-title">Jobs</div>
                <div class="section-contents">
                    @foreach (var category in GetJobCategories())
                    {
                        var teamColor = GetCategoryColor(category);
                        <div class="section-job-group">
                            <div class="section-job-titel" style="background-color: rgba(@(teamColor.r * 255), @(teamColor.g * 255), @(teamColor.b * 255), 0.6)">@category</div>
                            <div class="section-job-list">
                                @foreach (var job in GetJobsByCategory(category))
                                {
                                    var currentWorkers = GetCurrentWorkers(job);
                                    var maxDisplay = job.MaxWorkers == 0 ? "∞" : job.MaxWorkers.ToString();
                                    var isFull = job.MaxWorkers > 0 && currentWorkers >= job.MaxWorkers;
                                    var needsVIP = job.RequiresVIP && !(GameController?.GetMe()?.IsVIP ?? false);
                                    var isDisabled = isFull || needsVIP;

                                    <div class="section-job button @(isDisabled ? "disabled" : "")" onclick="@(() => SelectJob(job))" style="opacity: @(isDisabled ? "0.5" : "1")">
                                        <div class="icon" style="background-color: rgba(@(job.TeamColor.r * 255), @(job.TeamColor.g * 255), @(job.TeamColor.b * 255), 1)"></div>
                                        <div class="label-container">
                                            <div class="label">@job.Name @(job.RequiresVIP ? "(VIP)" : "")</div>
                                            <div class="description">@job.Description</div>
                                            <div class="description">Salary: <span style="color: #75a774;">$@(job.Salary.ToString("N0"))</span> | Slots: @currentWorkers / @maxDisplay</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Props Section -->
            <div class="section" style="display: @(IsPropsVisible ? "flex" : "none");">
                <div class="section-title">Props: @PropManager?.PropCount() / @PropManager?.PropLimit</div>
                <div class="section-contents">
                    <div class="info">
                        <!-- Local Props -->
                        <button class="button" style="justify-content:center; margin-top:10px; margin-bottom:20px; background-color:maroon;" onclick=@RemoveAllProps>
                            Remove all my props (Press "Z" to undo props)
                        </button>

                        <div style="flex-direction: row; flex-wrap:wrap;">
                            @foreach (var Model in Props)
                            {
                                string Propsname = Model.Name;
                                var DisplayableName = Regex.Replace(Model.ResourceName, @"0[1-99]", "");
                                var propThumbnailPath = PropManager.GetPropThumbnail(Propsname);

                                <div style="padding:8px;">
                                    <div class="button" onclick=@(() => SpawnProps(Propsname)) style="background-image: url('@propThumbnailPath'); background-size: cover; width:150px; height:150px; margin: 10px;">
                                </div>
                                </div>
                            }
                        </div>

                        <!-- Cloud Assets -->
                        <div class="section-title">Cloud Assets</div>
                        <div style="flex-direction: row; flex-wrap:wrap; margin-top: 20px;">
                            @if (CloudPackages != null && CloudPackages.Count > 0 && PropManager.UseCloudProps)
                            {
                                @foreach (var package in CloudPackages)
                                {
                                    var thumbnailPath = package.Thumb;

                                    <div class="button" onclick=@(() => SpawnCloudProp(package.FullIdent)) style="background-image: url(@thumbnailPath); background-size: cover; width:150px; height:150px; margin: 10px;">
                                    </div>
                                }
                            }
                            else
                            {
                                <div>No cloud models available.</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Information Section -->
            <div class="section" style="display: @(IsInfoVisible ? "flex" : "none");">
                <div class="section-title">Information</div>
                <div class="section-contents">
                    <div class="info" style="color: white;">
                        <h1>Notes</h1>
                        <p>@InfoNotes</p>
                    </div>

                    <div class="info" style="color: #DCDCDC;">
                        <h1>Credits</h1>
                        <p>@InfoCredits</p>
                    </div>

                    <div class="info" style="color: #DAA520; ">
                        <h1>Controls</h1>
                        <ul style="flex-direction:column; font-size:20px;"> @foreach(var control in Controls) { <li> @control</li> } </ul>
                    </div>

                </div>
            </div>

            <!-- Admin Section -->
            <div class="section" style="display: @(IsAdminVisible ? "flex" : "none");">
                <div class="section-title">Admin Tools</div>
                <div class="section-contents">
                    <div class="info" style="color: red;">
                        <h1>TODO</h1>
                    </div>
                </div>
            </div>
        </div>
    </div>
</root>

@code {
    [Property] GameObject PrinterPrefab { get; set; }
    [Property] GameObject VehiclePrefab { get; set; }
    [Property] Player Player { get; set; }

    // Printer tracking
    int CurrentPrinter = 0;

    // Vehicle tracking
    int CurrentVehicleCount => VehicleManager.GetVehicleCount(Player?.Network?.OwnerId ?? Guid.Empty);

    void BuyPrinter(PrinterLogic.PrinterType type)
    {
        if (CurrentPrinter >= BustasConfig.MaxPrintersPerPlayer)
        {
            Sound.Play("audio/error.sound");
            return;
        }

        // Check VIP requirement for Emerald
        var config = PrinterLogic.GetTierConfig(type);
        if (config.RequiresVIP)
        {
            var networkPlayer = GameController?.GetMe();
            if (networkPlayer != null && !networkPlayer.IsVIP)
            {
                Sound.Play("audio/error.sound");
                return;
            }
        }

        if (!Player.UpdateBalance(-config.Cost))
        {
            return;
        }

        Vector3 playerPos = GameObject.Parent.Transform.World.Position + GameObject.Parent.Transform.Local.Forward * 50;
        GameObject printer = PrinterPrefab.Clone(playerPos);

        printer.Components.Get<PrinterLogic>().SetPrinterType(type);

        printer.NetworkSpawn();
        CurrentPrinter++;
    }

    [Property] public List<Model> Props { get; set; } = new List<Model>();
    private List<Package> CloudPackages { get; set; } = new List<Package>();
    PropToolManager PropManager { get; set; }
    private GameController GameController;

    // Information tab properties
    [Property, TextArea] public string InfoNotes { get; set; } = "Important notes...";
    [Property, TextArea] public string InfoCredits { get; set; } = "Credits for the team...";
    [Property] public List<String> Controls { get; set; }

    protected override void OnStart()
    {
        try
        {
            PropManager = GameObject.Parent.Components.Get<PropToolManager>();
            GameController = GameController.Instance;

            // Load Cloud Packages
            _ = LoadCloudPackages("model");
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to initialize: {ex.Message}");
        }
    }

    private async Task LoadCloudPackages(string query)
    {
        try
        {
            var result = await Package.FindAsync(query);
            if (result != null && result.Packages != null)
            {
                CloudPackages = result.Packages.ToList();
                StateHasChanged();
            }
            else
            {
                Log.Warning("No packages found matching the query.");
            }
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to load cloud packages: {ex.Message}");
        }
    }

    // ── Job Helpers ────────────────────────────────────────────────

    /// <summary>
    /// Get unique job categories ordered: Civilians, Government, Criminals
    /// </summary>
    List<string> GetJobCategories()
    {
        var categories = JobProvider.Jobs.Values
            .Where(j => !string.IsNullOrEmpty(j.Category))
            .Select(j => j.Category)
            .Distinct()
            .ToList();

        // Sort in preferred order
        var order = new List<string> { "Civilians", "Government", "Criminals" };
        categories.Sort((a, b) =>
        {
            int ia = order.IndexOf(a);
            int ib = order.IndexOf(b);
            if (ia == -1) ia = 999;
            if (ib == -1) ib = 999;
            return ia.CompareTo(ib);
        });

        return categories;
    }

    Color GetCategoryColor(string category)
    {
        return category switch
        {
            "Government" => BustasTeamColors.Government,
            "Criminals" => BustasTeamColors.Criminals,
            _ => BustasTeamColors.Civilians
        };
    }

    List<JobResource> GetJobsByCategory(string category)
    {
        return JobProvider.Jobs.Values
            .Where(j => j.Category == category)
            .OrderBy(j => j.SortingLevel)
            .ToList();
    }

    int GetCurrentWorkers(JobResource job)
    {
        if (GameController == null) return 0;
        return GameController.GetAllPlayers().Values
            .Count(p => p.Job?.Name == job.Name);
    }

    void SelectJob(JobResource job)
    {
        if (job.MaxWorkers > 0)
        {
            int current = GetCurrentWorkers(job);
            if (current >= job.MaxWorkers)
            {
                Sound.Play("audio/error.sound");
                return;
            }
        }

        // Check VIP requirement
        if (job.RequiresVIP && !(GameController?.GetMe()?.IsVIP ?? false))
        {
            Sound.Play("audio/error.sound");
            return;
        }

        GameController.SelectJob(Player.Network.OwnerId, job);
        Sound.Play("audio/select.sound");
    }

    // ── Prop Helpers ───────────────────────────────────────────────

    void SpawnProps(string modelname)
    {
        if (PropManager == null)
        {
            Log.Error("PropManager not found");
            return;
        }
        PropManager.SpawnProp(modelname);
    }

    async Task SpawnCloudProp(string fullIdent)
    {
        try
        {
            var package = await Package.FetchAsync(fullIdent, true);

            if (package != null)
            {
                Log.Info($"Package {package.Title} fetched successfully.");

                var installedPackage = await package.MountAsync();

                if (installedPackage != null)
                {
                    Log.Info($"Package {package.Title} downloaded and mounted successfully.");

                    var propToolManager = GameObject.Components.Get<PropToolManager>() ??
                                        GameObject.Parent?.Components.Get<PropToolManager>();

                    if (propToolManager != null)
                    {
                        Vector3 position = GameObject.Transform.Position + Vector3.Up * 50;
                        Rotation rotation = Rotation.Identity;

                        propToolManager.SpawnCloudModel(fullIdent, position, rotation);
                        Log.Info($"Cloud model {fullIdent} spawned successfully.");
                    }
                    else
                    {
                        Log.Warning("PropToolManager not found on the game object or its parent.");
                    }
                }
                else
                {
                    Log.Warning($"Failed to mount package: {fullIdent}");
                }
            }
            else
            {
                Log.Warning($"Could not fetch package with identifier: {fullIdent}");
            }
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to spawn cloud model: {ex.Message}");
        }
    }

    void RemoveAllProps()
    {
        if (PropManager == null)
        {
            Log.Error("PropManager not found");
            return;
        }
        PropManager.RemoveAllProps();
    }

    // ── Section Visibility ─────────────────────────────────────────

    bool IsDarkWebVisible = false,
         IsJobsVisible = true,
         IsInfoVisible = false,
         IsAdminVisible = false,
         IsPropsVisible = false,
         IsVehiclesVisible = false;

    void DisplaySection(string section)
    {
        IsDarkWebVisible = section == "DarkWeb";
        IsJobsVisible = section == "Jobs";
        IsInfoVisible = section == "Info";
        IsAdminVisible = section == "Admin";
        IsPropsVisible = section == "Props";
        IsVehiclesVisible = section == "Vehicles";

        Sound.Play("audio/select.sound");
    }

    void DisplayDarkWeb() { DisplaySection("DarkWeb"); }
    void DisplayJobs() { DisplaySection("Jobs"); }
    void DisplayInfo() { DisplaySection("Info"); }
    void DisplayAdmin() { DisplaySection("Admin"); }
    void DisplayProps() { DisplaySection("Props"); }
    void DisplayVehicles() { DisplaySection("Vehicles"); }

    // ── Vehicle Helpers ─────────────────────────────────────────────

    bool CanUseVehicle(VehicleConfig config)
    {
        var me = GameController?.GetMe();
        if (me == null) return false;
        return VehicleConfigs.CanPlayerUse(config, me.Job?.Name ?? "", me.IsVIP);
    }

    string GetVehicleRestriction(VehicleConfig config)
    {
        if (config.RequiresVIP) return "(VIP)";
        if (config.RequiredJob != null) return $"({config.RequiredJob})";
        return "";
    }

    void SpawnVehicle(VehicleType type)
    {
        if (VehiclePrefab == null)
        {
            Log.Error("VehiclePrefab not set");
            return;
        }

        var me = GameController?.GetMe();
        if (me == null) return;

        var config = VehicleConfigs.Get(type);

        // Check job/VIP restriction
        if (!VehicleConfigs.CanPlayerUse(config, me.Job?.Name ?? "", me.IsVIP))
        {
            Sound.Play("audio/error.sound");
            return;
        }

        // Check vehicle limit
        if (VehicleManager.GetVehicleCount(me.Connection.Id) >= BustasConfig.MaxVehiclesPerPlayer)
        {
            Sound.Play("audio/error.sound");
            return;
        }

        // Check spawn cooldown
        if (VehicleManager.IsOnCooldown(me.Connection.Id))
        {
            Sound.Play("audio/error.sound");
            return;
        }

        // Check cost
        if (!config.IsFree && !Player.UpdateBalance(-config.Cost))
        {
            return;
        }

        // Spawn the vehicle
        Vector3 playerPos = GameObject.Parent.Transform.World.Position + GameObject.Parent.Transform.Local.Forward * 150;
        GameObject vehicle = VehiclePrefab.Clone(playerPos);

        var vehicleLogic = vehicle.Components.Get<VehicleLogic>();
        if (vehicleLogic != null)
        {
            vehicleLogic.SetVehicleType(type);
            vehicleLogic.SetOwner(me.Connection.Id, me.Name);
        }

        vehicle.NetworkSpawn();
        VehicleManager.RegisterVehicle(me.Connection.Id, vehicle);
        VehicleManager.SetCooldown(me.Connection.Id);
        Sound.Play("audio/select.sound");
    }

    string Discord = "Discord";
    string GitHub = "GitHub";

    async void DiscordLink()
    {
        Sound.Play("audio/select.sound");
        try
        {
            Clipboard.SetText("https://discord.gg/yBDk9Xr6VB");
            Discord = "Discord - Copied!";
            await Task.Delay(1500);
            Discord = "Discord";
            StateHasChanged();
        }
        catch
        {
            Log.Error("Failed to copy to clipboard");
        }
    }

    async void GitHubLink()
    {
        Sound.Play("audio/select.sound");
        try
        {
            Clipboard.SetText("https://github.com/sousou63/DarkRP");
            GitHub = "GitHub - Copied!";
            await Task.Delay(1500);
            GitHub = "GitHub";
            StateHasChanged();
        }
        catch
        {
            Log.Error("Failed to copy to clipboard");
        }
    }

    protected override int BuildHash() => System.HashCode.Combine(PropManager?.PropCount(), CurrentPrinter, CurrentVehicleCount);
}
