@namespace GameSystems.UI
@using global::GameSystems
@using global::GameSystems.LawOrder
@using global::Scenebox
@using Sandbox;
@using Sandbox.GameSystems;
@using Sandbox.GameSystems.Player;
@inherits PanelComponent

<root>
    @{
        Player stats = PlayerPrefab?.Components.Get<Player>();
        if ( stats == null ) { return; }

        float health = stats.Health.Floor();
        float maxHealth = stats.MaxHealth.Floor();
        int healthPercentage = maxHealth > 0 ? (health / maxHealth * 100).FloorToInt() : 0;

        float food = stats.Hunger.Floor();
        float maxFood = stats.HungerMax.Floor();
        int foodPercentage = maxFood > 0 ? ((food / maxFood) * 100).FloorToInt() : 0;

        var networkPlayer = stats.GetNetworkPlayer();
        var jobName = networkPlayer?.Job?.Name ?? "Citizen";
        var teamColor = networkPlayer?.Job?.TeamColor.Hex ?? "#ffffff";
        var isWanted = networkPlayer != null && WantedManager.IsWanted( networkPlayer.Connection.Id );
        var wantedReason = isWanted ? WantedManager.GetWantedReason( networkPlayer.Connection.Id ) : "";
    }
    <div class="key-instructions">@MyStringValue</div>

    @if ( isWanted )
    {
        <div class="wanted-indicator">
            <i class="icon">warning</i>
            <span class="wanted-text">WANTED</span>
            <span class="wanted-reason">@wantedReason</span>
        </div>
    }

    <div class="player-card">
        <div class="name">@Network.Owner.DisplayName.Truncate(13)</div>
        <div class="player-details-container">
            <div class="money">$@(stats.Balance.ToString("N0"))</div>
            <div class="job" style="color: @teamColor">@jobName</div>
        </div>
        <div class="bars">
            <div class="bar">
                <div class="fill fill--health" style="width:@(healthPercentage)%;"/>
                <div class="bar-icon"><i class="icon">favorite</i></div>
                <div class="bar-text">@(health.ToString("N0")) / @(maxHealth.ToString("N0"))</div>
            </div>
            <div class="bar">
                <div class="fill fill--food" style="width:@(foodPercentage)%;"/>
                <div class="bar-icon"><i class="icon">restaurant</i></div>
                <div class="bar-text">@(food.ToString("N0")) / @(maxFood.ToString("N0"))</div>
            </div>
        </div>
    </div>

    <div class="crosshair">
    </div>

    <div class="notifications">
        @foreach (var notification in Notifications)
        {
            <div class="notification notification--@notification.type.ToString().ToLower()">
                @if (notification.type == NotificationType.Info)
                {
                    <i class="icon">info</i>
                }
                else if (notification.type == NotificationType.Warning)
                {
                    <i class="icon">warning</i>
                }
                else if (notification.type == NotificationType.Error)
                {
                    <i class="icon">error</i>
                }
                else if (notification.type == NotificationType.Money)
                {
                    <i class="icon">attach_money</i>
                }
                else if (notification.type == NotificationType.Death)
                {
                    <i class="icon">skull</i>
                }
                else if (notification.type == NotificationType.Arrest)
                {
                    <i class="icon">gavel</i>
                }
                else if (notification.type == NotificationType.VIP)
                {
                    <i class="icon">star</i>
                }
                <div class="message">@notification.message</div>
            </div>
        }
    </div>

    <div class="inventory @(stats.IsInventoryVisible ? "visible" : "")">
        @for (int i = 1; i <= Player.MaxSlots; i++)
        {
            var weapon = stats.InventorySlots != null ? stats.InventorySlots[i - 1] : null;
            var thumbnail = weapon?.WorldModel != null ? $"{weapon.WorldModel.Name.ToLower().Replace(".vmdl", "")}.vmdl_c.png" : "";

            <div class="slot @(i == stats.CurrentSelectedSlot ? "active" : "")">@i
                <image src="@thumbnail" style="border-radius: 5px 5px 5px 5px;"></image>
            </div>
        }
    </div>

    @{
        var activeWeapon = GetActiveWeapon();
    }
    @if ( activeWeapon != null && activeWeapon.Resource != null && activeWeapon.Resource.HasAmmo )
    {
        <div class="ammo-display">
            <span class="ammo-clip">@activeWeapon.CurrentClip</span>
            <span class="ammo-separator">/</span>
            <span class="ammo-reserve">@activeWeapon.ReserveAmmo</span>
            @if ( activeWeapon.IsReloading )
            {
                <span class="ammo-reloading">RELOADING</span>
            }
        </div>
    }

</root>

@code
{
    [Property] GameObject PlayerPrefab { get; set; } // Reference my Player Prefab code to acces my component :@(PlayerPrefab.Components.Get<Stats>().Balance)

    [Property, TextArea] public string MyStringValue { get; set; } = "Hello World!";

    public enum NotificationType
    {
        Info,
        Warning,
        Error,
        Money,
        Death,
        Arrest,
        VIP
    }
    record Notification(NotificationType type, string message, RealTimeSince timeSinceAdded);
    List<Notification> Notifications { get; set; } = new();
    public void Notify(NotificationType type, string message)
    {
        switch (type)
        {
            case NotificationType.Info:
                Sound.Play("audio/select.sound");
                break;
            case NotificationType.Money:
                Sound.Play("audio/Notification.sound");
                break;
            case NotificationType.VIP:
                Sound.Play("audio/Notification.sound");
                break;
            default:
                Sound.Play("audio/error.sound");
                break;
        }
        Notifications.Add(new Notification(type, message, 0));
    }

    protected override void OnFixedUpdate()
    {
        Notifications.RemoveAll(x => x.timeSinceAdded > 5);
    }

    private Weapon GetActiveWeapon()
    {
        if ( PlayerPrefab == null ) return null;
        return PlayerPrefab.Components.GetInDescendants<Weapon>();
    }

    /// <summary>
    /// the hash determines if the system should be rebuilt. If it changes, it will be rebuilt
    /// </summary>
    protected override int BuildHash()
    {
	    var player = PlayerPrefab?.Components.Get<Player>();
	    if ( player == null ) return 0;
	    var networkPlayer = player.GetNetworkPlayer();
	    var isWanted = networkPlayer != null && WantedManager.IsWanted( networkPlayer.Connection.Id );
	    var weapon = GetActiveWeapon();
	    return System.HashCode.Combine( MyStringValue,
		    networkPlayer?.Job?.Name,
		    player.Balance,
		    player.Hunger,
		    player.Health,
		    player.IsInventoryVisible,
		    System.HashCode.Combine( player.CurrentSelectedSlot, Notifications.Count, isWanted, weapon?.CurrentClip, weapon?.IsReloading )
	    );
    }
}
